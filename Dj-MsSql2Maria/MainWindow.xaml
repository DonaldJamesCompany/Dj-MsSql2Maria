<Window x:Class="Dj_MsSql2Maria.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dj_MsSql2Maria"
        mc:Ignorable="d"
        Title="MS SQL to MariaDB 1.0.0 (Dj-MsSql2Maria)"
        ResizeMode="CanMinimize"
        SizeToContent="Height"
        Width="480"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Padding" Value="6,4,6,6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,2,4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,3"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="10,8,10,10">

        <!-- Input Type -->
        <GroupBox Header="Input">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Label Content="Type:" Width="50"/>
                    <ComboBox x:Name="CmbInputType" Width="220"
                              SelectionChanged="CmbInputType_SelectionChanged">
                        <ComboBoxItem Content="Single .SQL File"     IsSelected="True"/>
                        <ComboBoxItem Content="Multiple .SQL Files"/>
                        <ComboBoxItem Content="MS SQL Server .BAK File"/>
                    </ComboBox>
                </StackPanel>

                <!-- Single / Multiple file row -->
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2"
                            x:Name="PnlFileRow">
                    <Label Content="File(s):" Width="50"/>
                    <TextBox x:Name="TxtInputPath" Width="310" IsReadOnly="True"/>
                    <Button Content="Browse…" Margin="4,0,0,0"
                            Click="BtnBrowseInput_Click"/>
                </StackPanel>

                <!-- BAK-specific options -->
                <StackPanel x:Name="PnlBakOptions" Visibility="Collapsed" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="ChkBakTables" Content="Create MariaDB script for Tables?" IsChecked="True" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkBakTablesIndividual" Content="Individual or Consolidated .SQL files?" IsChecked="False" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <CheckBox x:Name="ChkBakData" Content="Create MariaDB script for Data?" IsChecked="True" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkBakDataIndividual" Content="Individual or Consolidated .SQL files?" IsChecked="False" Margin="16,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Output -->
        <GroupBox Header="Output">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <Label Content="Folder:" Width="50"/>
                    <TextBox x:Name="TxtOutputFolder" Width="310" IsReadOnly="True"/>
                    <Button Content="Browse…" Margin="4,0,0,0"
                            Click="BtnBrowseOutput_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                    <CheckBox x:Name="ChkAppendSuffix"
                              Content="Append to filename?"
                              Checked="ChkAppendSuffix_Changed"
                              Unchecked="ChkAppendSuffix_Changed"/>
                    <TextBox x:Name="TxtSuffix" Width="120" Margin="6,0,0,0"
                             IsEnabled="False" Text="_MariaDb"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Log -->
        <GroupBox Header="Log">
            <ScrollViewer Height="110" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="TxtLog"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="#FF000000"
                         Foreground="#FFFFFF00"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         HorizontalAlignment="Stretch"
                         VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Progress -->
        <ProgressBar x:Name="PrgBar" Height="12" Margin="0,6,0,0"
                     Minimum="0" Maximum="100" Value="0"/>

        <!-- Status -->
        <GroupBox Header="Status" Margin="0,6,0,0">
            <ScrollViewer x:Name="StatusScroller" Height="70"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBox x:Name="TxtStatus"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="#FF000000"
                         Foreground="#FF00FF00"
                         FontFamily="Consolas"
                         FontSize="11"
                         BorderThickness="0"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         HorizontalAlignment="Stretch"
                         VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </GroupBox>

        <!-- Action buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="BtnStop"    Content="STOP"     IsEnabled="False"
                    Background="#FFFFD0D0"
                    Click="BtnStop_Click"/>
            <Button x:Name="BtnClear"   Content="CLEAR"    Margin="8,0,0,0"
                    Click="BtnClear_Click"/>
            <Button x:Name="BtnGo"      Content="GO"       Margin="8,0,0,0"
                    Background="#FFD0FFD0"
                    Click="BtnGo_Click"/>
            <Button x:Name="BtnViewLog" Content="VIEW LOG" Margin="8,0,0,0"
                    IsEnabled="False"
                    Click="BtnViewLog_Click"/>
            <Button x:Name="BtnExit"    Content="EXIT"     Margin="8,0,0,0"
                    Click="BtnExit_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
